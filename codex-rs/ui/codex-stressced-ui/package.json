{
  "name": "codex-stressced-ui",
  "version": "0.1.0",
  "description": "Local Electron UI for Codex Stressced",
  "author": "Stressced",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5174 && electron .\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build:backend": "node build-backend.mjs",
    "build": "npm run typecheck && npm run build:backend && vite build && node build-electron.mjs && electron-builder",
    "build:frontend": "vite build",
    "build:electron": "node build-electron.mjs",
    "start": "electron ."
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^15.6.1",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^10.0.3",
    "electron": "^38.3.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.5",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "local.codexstressced.ui",
    "productName": "Codex Stressced",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist-backend/codexstressced.exe",
        "to": "codexstressced.exe"
      }
    ],
    "win": {
      "target": [
        "portable"
      ]
    }
  }
}
